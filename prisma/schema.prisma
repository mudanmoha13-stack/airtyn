generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  active
  trialing
  suspended
  archived
}

enum UserRole {
  owner
  admin
  member
}

enum UserStatus {
  invited
  active
  disabled
}

enum ProjectStatus {
  active
  archived
  completed
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum MilestoneStatus {
  pending
  completed
}

enum InvitationStatus {
  pending
  accepted
  revoked
}

enum RoleScope {
  system
  tenant
  project
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
}

enum InvoiceStatus {
  draft
  open
  paid
  void
  uncollectible
}

enum NotificationType {
  task_assigned
  task_due
  comment_added
  invitation
  billing
  system
}

enum IntegrationType {
  slack
  email
  github
  jira
  custom
}

enum IntegrationStatus {
  active
  inactive
  error
}

enum WebhookStatus {
  active
  disabled
  failing
}

enum DependencyType {
  finish_to_start
  start_to_start
  finish_to_finish
  start_to_finish
}

model Plan {
  id             String         @id @default(cuid())
  code           String         @unique
  name           String
  description    String?
  priceMonthly   Int            @default(0) @map("price_monthly")
  priceYearly    Int            @default(0) @map("price_yearly")
  maxUsers       Int?           @map("max_users")
  maxProjects    Int?           @map("max_projects")
  features       Json?
  status         String         @default("active")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")
  tenants        Tenant[]
  subscriptions  Subscription[]
  invoices       Invoice[]

  @@map("plans")
}

model Tenant {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  plan          String
  planId        String?         @map("plan_id")
  status        TenantStatus    @default(active)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")
  planRelation  Plan?           @relation(fields: [planId], references: [id], onDelete: SetNull)
  workspaces    Workspace[]
  users         User[]
  memberships   UserTenant[]
  roles         Role[]
  projects      Project[]
  milestones    Milestone[]
  tasks         Task[]
  labels        TaskLabel[]
  taskComments  TaskComment[]
  taskDeps      TaskDependency[]
  taskChecklists TaskChecklist[]
  timeEntries   TimeEntry[]
  invitations   Invitation[]
  notifications Notification[]
  activityLogs  ActivityLog[]
  auditLogs     AuditLogEntry[]
  subscriptions Subscription[]
  invoices      Invoice[]
  webhooks      Webhook[]
  integrations  Integration[]
  files         File[]

  @@index([planId])
  @@map("tenants")
}

model Workspace {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects    Project[]

  @@index([tenantId, name])
  @@map("workspaces")
}

model Department {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  users     User[]

  @@map("departments")
}

model User {
  id             String           @id @default(cuid())
  tenantId       String           @map("tenant_id")
  departmentId   String?          @map("department_id")
  name           String           @map("full_name")
  email          String           @unique
  passwordHash   String           @default("") @map("password_hash")
  status         UserStatus       @default(active)
  lastLoginAt    DateTime?        @map("last_login_at")
  avatarUrl      String?          @map("avatar_url")
  role           UserRole
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department     Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  memberships    UserTenant[]
  ownedProjects  Project[]        @relation("ProjectOwner")
  projectMembers ProjectMember[]
  tasks          Task[]           @relation("TaskAssignee")
  taskAssignees  TaskAssignee[]
  createdTasks   Task[]           @relation("TaskCreator")
  comments       TaskComment[]
  timeEntries    TimeEntry[]
  files          File[]           @relation("FileUploader")
  notifications  Notification[]
  activityLogs   ActivityLog[]    @relation("ActivityActor")
  auditLogs      AuditLogEntry[]  @relation("AuditActor")
  invitations    Invitation[]     @relation("InvitationInviter")

  @@index([tenantId, email])
  @@index([departmentId])
  @@map("users")
}

model UserTenant {
  id        String     @id @default(cuid())
  userId    String     @map("user_id")
  tenantId  String     @map("tenant_id")
  roleId    String     @map("role_id")
  joinedAt  DateTime   @default(now()) @map("joined_at")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, tenantId])
  @@index([tenantId, roleId])
  @@map("user_tenants")
}

model Role {
  id             String           @id @default(cuid())
  tenantId       String?          @map("tenant_id")
  name           String
  slug           String
  description    String?
  scope          RoleScope        @default(tenant)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")
  tenant         Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions    RolePermission[]
  memberships    UserTenant[]
  projectMembers ProjectMember[]

  @@unique([tenantId, slug])
  @@index([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String      @id @default(cuid())
  roleId       String      @map("role_id")
  permissionId String      @map("permission_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Project {
  id           String          @id @default(cuid())
  tenantId     String          @map("tenant_id")
  workspaceId  String?         @map("workspace_id")
  ownerId      String          @map("owner_id")
  name         String
  description  String
  status       ProjectStatus
  owner        User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace    Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  startDate    DateTime?       @map("start_date")
  endDate      DateTime?       @map("end_date")
  budget       Decimal?        @db.Decimal(12, 2)
  progress     Int             @default(0)
  templateId   String?         @map("template_id")
  color        String?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")
  members      ProjectMember[]
  tasks        Task[]
  milestones   Milestone[]
  files        File[]
  webhooks     Webhook[]

  @@index([tenantId, workspaceId])
  @@index([tenantId, ownerId])
  @@map("projects")
}

model ProjectMember {
  id        String     @id @default(cuid())
  projectId  String     @map("project_id")
  userId      String     @map("user_id")
  roleId      String?    @map("role_id")
  joinedAt    DateTime   @default(now()) @map("joined_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role?      @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([projectId, userId])
  @@index([userId, roleId])
  @@map("project_members")
}

model Task {
  id               String               @id @default(cuid())
  tenantId         String               @map("tenant_id")
  projectId        String               @map("project_id")
  parentTaskId     String?              @map("parent_task_id")
  milestoneId      String?              @map("milestone_id")
  title            String
  description      String
  status           TaskStatus
  priority         TaskPriority
  assigneeId       String?              @map("assignee_id")
  dueDate          DateTime?            @map("due_date")
  startDate        DateTime?            @map("start_date")
  estimatedHours   Decimal?             @map("estimated_hours") @db.Decimal(8, 2)
  estimatedMinutes Int?                 @map("estimated_minutes")
  tags             Json?
  timeEntries      Json?                @map("time_entries_json")
  attachments      Json?                @map("attachments_json")
  createdBy        String               @map("created_by")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  deletedAt        DateTime?            @map("deleted_at")
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project          Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone        Milestone?           @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  assignee         User?                @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator          User                 @relation("TaskCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  parentTask       Task?                @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasksNested   Task[]               @relation("TaskHierarchy")
  comments         TaskComment[]
  subtasks         Subtask[]
  checklistItems   TaskChecklist[]
  labelLinks       TaskLabelAssignment[]
  assignees        TaskAssignee[]
  dependenciesFrom TaskDependency[]     @relation("DependencyFrom")
  dependenciesTo   TaskDependency[]     @relation("DependencyTo")
  timeEntryRows    TimeEntry[]
  files            File[]

  @@index([tenantId, projectId, status])
  @@index([tenantId, assigneeId])
  @@index([tenantId, dueDate])
  @@map("tasks")
}

model Milestone {
  id          String           @id @default(cuid())
  tenantId    String?          @map("tenant_id")
  projectId   String           @map("project_id")
  title       String
  description String
  dueDate     DateTime         @map("due_date")
  status      MilestoneStatus
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([projectId, dueDate])
  @@map("milestones")
}

model Subtask {
  id        String    @id @default(cuid())
  taskId     String    @map("task_id")
  title      String
  completed  Boolean   @default(false)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_checklists_legacy")
}

model TaskComment {
  id         String    @id @default(cuid())
  tenantId    String?   @map("tenant_id")
  taskId      String    @map("task_id")
  userId      String    @map("user_id")
  content     String    @map("comment_body")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, taskId])
  @@map("task_comments")
}

model TaskAssignee {
  id         String    @id @default(cuid())
  taskId      String    @map("task_id")
  userId      String    @map("user_id")
  assignedAt  DateTime  @default(now()) @map("assigned_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId, assignedAt])
  @@map("task_assignees")
}

model TaskDependency {
  id                 String         @id @default(cuid())
  tenantId           String         @map("tenant_id")
  predecessorTaskId  String         @map("predecessor_task_id")
  successorTaskId    String         @map("successor_task_id")
  type               DependencyType @default(finish_to_start)
  createdAt          DateTime       @default(now()) @map("created_at")
  predecessorTask    Task           @relation("DependencyFrom", fields: [predecessorTaskId], references: [id], onDelete: Cascade)
  successorTask      Task           @relation("DependencyTo", fields: [successorTaskId], references: [id], onDelete: Cascade)
  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([predecessorTaskId, successorTaskId])
  @@index([tenantId, successorTaskId])
  @@map("task_dependencies")
}

model TaskChecklist {
  id         String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  taskId      String    @map("task_id")
  title       String
  completed   Boolean   @default(false)
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([tenantId, taskId, sortOrder])
  @@map("task_checklists")
}

model TaskLabel {
  id         String                @id @default(cuid())
  tenantId    String                @map("tenant_id")
  name        String
  color       String?
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  deletedAt   DateTime?             @map("deleted_at")
  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks       TaskLabelAssignment[]

  @@unique([tenantId, name])
  @@map("task_labels")
}

model TaskLabelAssignment {
  id         String     @id @default(cuid())
  taskId      String     @map("task_id")
  labelId     String     @map("label_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  task        Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label       TaskLabel  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
  @@map("task_label_assignments")
}

model TimeEntry {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  taskId           String    @map("task_id")
  userId           String    @map("user_id")
  startTime        DateTime? @map("start_time")
  endTime          DateTime? @map("end_time")
  durationMinutes  Int       @map("duration_minutes")
  note             String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  task             Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, taskId])
  @@index([tenantId, userId, startTime])
  @@map("time_entries")
}

model File {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  projectId     String?   @map("project_id")
  taskId        String?   @map("task_id")
  uploadedById  String?   @map("uploaded_by_id")
  name          String
  mimeType      String    @map("mime_type")
  sizeBytes     Int       @map("size_bytes")
  storageKey    String?   @map("storage_key")
  publicUrl     String?   @map("public_url")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task          Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy    User?     @relation("FileUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([tenantId, projectId])
  @@index([tenantId, taskId])
  @@map("files")
}

model Invitation {
  id         String           @id @default(cuid())
  tenantId    String?          @map("tenant_id")
  email      String
  role       UserRole
  status     InvitationStatus
  invitedBy  String           @map("invited_by")
  invitedAt  DateTime         @default(now()) @map("invited_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  tenant     Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inviter    User             @relation("InvitationInviter", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([tenantId, email])
  @@map("invitations")
}

model Notification {
  id         String           @id @default(cuid())
  tenantId    String           @map("tenant_id")
  userId      String           @map("user_id")
  type        NotificationType
  title       String
  body        String
  isRead      Boolean          @default(false) @map("is_read")
  readAt      DateTime?        @map("read_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  deletedAt   DateTime?        @map("deleted_at")
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, createdAt])
  @@index([tenantId, isRead])
  @@map("notifications")
}

model ActivityLog {
  id          String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  actorId      String?   @map("actor_id")
  actorName    String    @map("actor_name")
  action       String
  resource     String
  resourceId   String    @map("resource_id")
  details      String?
  metadata     Json?
  createdAt    DateTime  @default(now()) @map("created_at")
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor        User?     @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, resource, resourceId])
  @@map("activity_logs")
}

model AuditLogEntry {
  id         String    @id @default(cuid())
  tenantId     String?   @map("tenant_id")
  actorId     String     @map("actor_id")
  actorName   String     @map("actor_name")
  actorEmail  String     @map("actor_email")
  action      String
  resource    String
  resourceId  String     @map("resource_id")
  details     String
  createdAt   DateTime   @default(now()) @map("created_at")
  tenant      Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor       User       @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
  @@index([tenantId, resource, resourceId])
  @@map("audit_logs")
}

model Subscription {
  id                     String             @id @default(cuid())
  tenantId               String             @map("tenant_id")
  provider               String
  providerSubscriptionId String             @map("provider_subscription_id")
  planId                 String             @map("plan_id")
  status                 SubscriptionStatus
  trialEndsAt            DateTime?          @map("trial_ends_at")
  renewalAt              DateTime?          @map("renewal_at")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  deletedAt              DateTime?          @map("deleted_at")
  tenant                 Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                   Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices               Invoice[]

  @@unique([provider, providerSubscriptionId])
  @@index([tenantId, status])
  @@map("subscriptions")
}

model Invoice {
  id                String        @id @default(cuid())
  tenantId          String        @map("tenant_id")
  subscriptionId    String?       @map("subscription_id")
  providerInvoiceId String?       @map("provider_invoice_id")
  planId            String?       @map("plan_id")
  amountCents       Int           @map("amount_cents")
  currency          String        @default("USD")
  status            InvoiceStatus
  issuedAt          DateTime?     @map("issued_at")
  dueAt             DateTime?     @map("due_at")
  paidAt            DateTime?     @map("paid_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  plan              Plan?         @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@map("invoices")
}

model Webhook {
  id              String         @id @default(cuid())
  tenantId        String         @map("tenant_id")
  projectId       String?        @map("project_id")
  integrationId   String?        @map("integration_id")
  name            String
  url             String
  secret          String
  events          Json?
  status          WebhookStatus  @default(active)
  lastTriggeredAt DateTime?      @map("last_triggered_at")
  lastStatus      String?        @map("last_status")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  integration     Integration?   @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@map("webhooks")
}

model Integration {
  id          String            @id @default(cuid())
  tenantId     String            @map("tenant_id")
  provider     String
  type         IntegrationType
  status       IntegrationStatus @default(active)
  config       Json?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  deletedAt    DateTime?         @map("deleted_at")
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  webhooks     Webhook[]

  @@index([tenantId, provider])
  @@map("integrations")
}
